rules_version = '2';

// Roomie security rules.
// - Raw questionnaire answers are PRIVATE to their owner. Compatibility is
//   computed server-side (Firebase Admin SDK via /api routes), which bypasses
//   these rules, so the client never reads anyone else's answers.
// - Profiles and groups are readable by any signed-in user.
// - WRITES are restricted to the owner / involved parties.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) && request.resource.data.uid == uid;
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    match /questionnaires/{uid} {
      // Private to the owner — matching runs server-side with the Admin SDK.
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && request.resource.data.uid == uid;
    }

    match /groups/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && (request.auth.uid in request.resource.data.memberUids);
      // Owner edits, or a user joining (must appear in the new member list).
      allow update: if isSignedIn() && (
        (request.auth.uid in resource.data.memberUids) ||
        (request.auth.uid in request.resource.data.memberUids)
      );
      allow delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /connections/{id} {
      allow read: if isSignedIn()
        && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn()
        && request.resource.data.from == request.auth.uid
        && (request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn()
        && (request.auth.uid in resource.data.participants);
      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.from;
    }

    match /meta/{id} {
      // Global meta docs (e.g. the matches version tick). Any signed-in user
      // can read so their match list stays in sync, and can bump on a
      // questionnaire write — the value is just an integer counter.
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /messages/{id} {
      // Only participants of a message can read it.
      allow read: if isSignedIn()
        && (request.auth.uid in resource.data.participants);
      // Sender must be the signed-in user and a participant; text length cap.
      allow create: if isSignedIn()
        && request.resource.data.from == request.auth.uid
        && (request.auth.uid in request.resource.data.participants)
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;
      // Allow the document id to be patched onto itself right after addDoc;
      // beyond that messages are immutable.
      allow update: if isSignedIn()
        && (request.auth.uid in resource.data.participants)
        && request.resource.data.text == resource.data.text
        && request.resource.data.from == resource.data.from
        && request.resource.data.to == resource.data.to
        && request.resource.data.createdAt == resource.data.createdAt;
      // Sender can delete their own message.
      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.from;
    }
  }
}
